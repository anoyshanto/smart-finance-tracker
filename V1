<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Finance Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root {
    --bg: #080d1a;
    --bg2: #0d1526;
    --bg3: #111d35;
    --bg4: #162240;
    --card: #0f1a30;
    --border: #1e2d4a;
    --border2: #243352;
    --primary: #2979ff;
    --primary-dim: rgba(41,121,255,0.12);
    --gold: #f5c518;
    --gold-dim: rgba(245,197,24,0.1);
    --green: #00e676;
    --green-dim: rgba(0,230,118,0.1);
    --red: #ff3d71;
    --red-dim: rgba(255,61,113,0.1);
    --cyan: #00e5ff;
    --purple: #d500f9;
    --text: #e8eaf6;
    --text2: #8899b8;
    --text3: #4a5d80;
    --mono: 'Space Mono', monospace;
    --sans: 'DM Sans', sans-serif;
    --radius: 12px;
    --sidebar: 240px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:var(--sans); background:var(--bg); color:var(--text); min-height:100vh; display:flex; overflow:hidden; }

  /* SIDEBAR */
  .sidebar {
    width:var(--sidebar); min-width:var(--sidebar);
    background:var(--bg2);
    border-right:1px solid var(--border);
    display:flex; flex-direction:column;
    height:100vh; overflow-y:auto;
    position:fixed; left:0; top:0; z-index:100;
  }
  .sidebar-logo {
    padding:24px 20px 16px;
    border-bottom:1px solid var(--border);
  }
  .logo-mark {
    font-family:var(--mono); font-size:11px; letter-spacing:2px;
    color:var(--gold); text-transform:uppercase; margin-bottom:4px;
  }
  .logo-name {
    font-size:17px; font-weight:700; color:var(--text);
    line-height:1.2;
  }
  .logo-sub { font-size:11px; color:var(--text3); margin-top:2px; }
  .nav-section { padding:16px 12px 8px; }
  .nav-label { font-size:10px; letter-spacing:1.5px; color:var(--text3); text-transform:uppercase; padding:0 8px; margin-bottom:6px; }
  .nav-item {
    display:flex; align-items:center; gap:10px;
    padding:9px 10px; border-radius:8px; cursor:pointer;
    color:var(--text2); font-size:13.5px; font-weight:500;
    transition:all 0.15s; margin-bottom:2px;
  }
  .nav-item:hover { background:var(--bg4); color:var(--text); }
  .nav-item.active { background:var(--primary-dim); color:var(--primary); }
  .nav-item .icon { font-size:16px; width:20px; text-align:center; }
  .nav-badge {
    margin-left:auto; font-size:10px; font-family:var(--mono);
    background:var(--gold-dim); color:var(--gold);
    padding:2px 6px; border-radius:4px;
  }
  .sidebar-footer {
    margin-top:auto; padding:16px;
    border-top:1px solid var(--border);
    font-size:11px; color:var(--text3);
    font-family:var(--mono);
  }

  /* MAIN */
  .main { margin-left:var(--sidebar); flex:1; height:100vh; overflow-y:auto; }
  .page { display:none; padding:28px 32px; min-height:100vh; animation:fadeIn 0.2s ease; }
  .page.active { display:block; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

  /* PAGE HEADER */
  .page-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:28px; }
  .page-title { font-size:24px; font-weight:700; }
  .page-sub { font-size:13px; color:var(--text3); margin-top:4px; }
  .btn {
    padding:9px 18px; border-radius:8px; cursor:pointer;
    font-family:var(--sans); font-size:13px; font-weight:600;
    border:none; transition:all 0.15s; display:inline-flex; align-items:center; gap:6px;
  }
  .btn-primary { background:var(--primary); color:#fff; }
  .btn-primary:hover { background:#1565c0; }
  .btn-outline { background:transparent; color:var(--text2); border:1px solid var(--border2); }
  .btn-outline:hover { border-color:var(--primary); color:var(--primary); }
  .btn-danger { background:var(--red-dim); color:var(--red); border:1px solid rgba(255,61,113,0.2); }
  .btn-danger:hover { background:var(--red); color:#fff; }
  .btn-sm { padding:6px 12px; font-size:12px; }

  /* CARDS */
  .card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:20px;
  }
  .card-title { font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--text3); margin-bottom:12px; font-weight:600; }

  /* KPI GRID */
  .kpi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
  .kpi-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:20px;
    position:relative; overflow:hidden;
  }
  .kpi-card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:2px;
  }
  .kpi-card.income::before { background:var(--green); }
  .kpi-card.expense::before { background:var(--red); }
  .kpi-card.profit::before { background:var(--primary); }
  .kpi-card.cash::before { background:var(--gold); }
  .kpi-label { font-size:11px; letter-spacing:1px; color:var(--text3); text-transform:uppercase; font-weight:600; }
  .kpi-value { font-family:var(--mono); font-size:26px; font-weight:700; margin:8px 0 4px; }
  .kpi-card.income .kpi-value { color:var(--green); }
  .kpi-card.expense .kpi-value { color:var(--red); }
  .kpi-card.profit .kpi-value { color:var(--primary); }
  .kpi-card.cash .kpi-value { color:var(--gold); }
  .kpi-change { font-size:12px; color:var(--text3); }

  /* GRIDS */
  .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }

  /* TABLE */
  .table-wrap { overflow-x:auto; }
  table { width:100%; border-collapse:collapse; font-size:13.5px; }
  th {
    padding:10px 14px; text-align:left;
    font-size:11px; letter-spacing:1px; color:var(--text3);
    text-transform:uppercase; font-weight:600;
    border-bottom:1px solid var(--border);
    background:var(--bg2);
  }
  td { padding:11px 14px; border-bottom:1px solid var(--border); vertical-align:middle; }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:rgba(255,255,255,0.02); }
  .mono { font-family:var(--mono); font-size:13px; }
  .text-green { color:var(--green); }
  .text-red { color:var(--red); }
  .text-gold { color:var(--gold); }
  .text-primary { color:var(--primary); }
  .text-muted { color:var(--text3); }
  .badge {
    display:inline-block; padding:3px 8px; border-radius:4px;
    font-size:11px; font-weight:600; font-family:var(--mono);
  }
  .badge-asset { background:rgba(0,229,255,0.1); color:var(--cyan); }
  .badge-liability { background:rgba(255,61,113,0.1); color:var(--red); }
  .badge-equity { background:rgba(213,0,249,0.1); color:var(--purple); }
  .badge-income { background:rgba(0,230,118,0.1); color:var(--green); }
  .badge-expense { background:rgba(245,197,24,0.1); color:var(--gold); }

  /* MODAL */
  .modal-overlay {
    display:none; position:fixed; inset:0;
    background:rgba(0,0,0,0.7); backdrop-filter:blur(4px);
    z-index:200; align-items:center; justify-content:center;
  }
  .modal-overlay.open { display:flex; }
  .modal {
    background:var(--bg3); border:1px solid var(--border2);
    border-radius:16px; padding:28px; width:520px; max-width:95vw;
    max-height:90vh; overflow-y:auto;
    animation:slideUp 0.2s ease;
  }
  @keyframes slideUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
  .modal-title { font-size:18px; font-weight:700; margin-bottom:20px; }
  .form-row { margin-bottom:16px; }
  .form-label { font-size:12px; color:var(--text2); font-weight:600; margin-bottom:6px; display:block; letter-spacing:0.5px; }
  .form-input, .form-select, .form-textarea {
    width:100%; padding:10px 14px;
    background:var(--bg2); border:1px solid var(--border2);
    border-radius:8px; color:var(--text); font-family:var(--sans); font-size:14px;
    outline:none; transition:border-color 0.15s;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color:var(--primary); }
  .form-select option { background:var(--bg2); }
  .form-textarea { resize:vertical; min-height:80px; }
  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .modal-footer { display:flex; gap:10px; justify-content:flex-end; margin-top:20px; }

  /* ALERT */
  .alert { padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:16px; }
  .alert-error { background:var(--red-dim); color:var(--red); border:1px solid rgba(255,61,113,0.2); }
  .alert-success { background:var(--green-dim); color:var(--green); border:1px solid rgba(0,230,118,0.2); }

  /* FILTER BAR */
  .filter-bar {
    display:flex; gap:10px; margin-bottom:18px;
    flex-wrap:wrap; align-items:center;
  }
  .filter-bar .form-input, .filter-bar .form-select { width:auto; }

  /* RATIO CARDS */
  .ratio-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  .ratio-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:20px; text-align:center;
  }
  .ratio-name { font-size:12px; color:var(--text3); text-transform:uppercase; letter-spacing:1px; margin-bottom:12px; }
  .ratio-val { font-family:var(--mono); font-size:32px; font-weight:700; color:var(--primary); }
  .ratio-desc { font-size:11px; color:var(--text3); margin-top:8px; }

  /* REPORT */
  .report-section { margin-bottom:28px; }
  .report-section h3 { font-size:13px; color:var(--text2); text-transform:uppercase; letter-spacing:1px; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--border); }
  .report-row { display:flex; justify-content:space-between; padding:7px 0; font-size:14px; border-bottom:1px solid rgba(255,255,255,0.03); }
  .report-row.total { font-weight:700; border-top:1px solid var(--border2); margin-top:4px; padding-top:10px; }
  .report-row.sub { padding-left:16px; color:var(--text2); font-size:13px; }
  .report-val { font-family:var(--mono); }

  /* TOAST */
  .toast {
    position:fixed; bottom:24px; right:24px;
    background:var(--bg3); border:1px solid var(--border2);
    padding:12px 18px; border-radius:10px;
    font-size:13px; z-index:999;
    animation:toastIn 0.3s ease;
    display:none;
  }
  .toast.show { display:block; }
  @keyframes toastIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width:6px; height:6px; }
  ::-webkit-scrollbar-track { background:var(--bg); }
  ::-webkit-scrollbar-thumb { background:var(--border2); border-radius:3px; }

  /* CHART WRAPPER */
  .chart-wrap { position:relative; height:220px; }
  .chart-wrap-tall { position:relative; height:280px; }

  /* TABS */
  .tabs { display:flex; gap:4px; margin-bottom:20px; background:var(--bg2); padding:4px; border-radius:10px; width:fit-content; }
  .tab { padding:7px 16px; border-radius:7px; cursor:pointer; font-size:13px; font-weight:500; color:var(--text3); transition:all 0.15s; }
  .tab.active { background:var(--primary); color:#fff; }

  /* EMPTY STATE */
  .empty { text-align:center; padding:48px 20px; color:var(--text3); }
  .empty-icon { font-size:40px; margin-bottom:12px; }
  .empty-text { font-size:14px; }

  /* LEDGER */
  .ledger-balance { font-family:var(--mono); font-size:20px; font-weight:700; }

  /* Budget bar */
  .budget-bar { height:6px; background:var(--border); border-radius:3px; margin-top:8px; overflow:hidden; }
  .budget-fill { height:100%; border-radius:3px; transition:width 0.5s; }

  @media(max-width:1100px) {
    .kpi-grid { grid-template-columns:repeat(2,1fr); }
    .ratio-grid { grid-template-columns:repeat(2,1fr); }
  }

  /* FORECAST MODULE */
  .forecast-hero {
    background: linear-gradient(135deg, rgba(41,121,255,0.08) 0%, rgba(0,229,255,0.05) 50%, rgba(213,0,249,0.06) 100%);
    border: 1px solid var(--border2); border-radius: 16px;
    padding: 24px 28px; margin-bottom: 20px;
    position: relative; overflow: hidden;
  }
  .forecast-hero::before {
    content: 'PREDICTIVE ENGINE';
    position: absolute; top: 16px; right: 20px;
    font-family: var(--mono); font-size: 10px; letter-spacing: 2px;
    color: var(--primary); opacity: 0.5;
  }
  .model-selector { display: flex; gap: 8px; flex-wrap: wrap; }
  .model-btn {
    padding: 7px 14px; border-radius: 20px; cursor: pointer;
    font-size: 12px; font-weight: 600; font-family: var(--sans);
    border: 1px solid var(--border2); background: transparent;
    color: var(--text3); transition: all 0.2s;
  }
  .model-btn.active { background: var(--primary); border-color: var(--primary); color: #fff; }
  .model-btn:hover:not(.active) { border-color: var(--primary); color: var(--primary); }
  .scenario-tabs { display: flex; gap: 6px; margin-bottom: 16px; }
  .scenario-btn {
    padding: 6px 16px; border-radius: 6px; cursor: pointer;
    font-size: 12px; font-weight: 600; border: 1px solid var(--border2);
    background: transparent; color: var(--text3); transition: all 0.15s;
  }
  .scenario-btn.optimistic.active { background: rgba(0,230,118,0.15); border-color: var(--green); color: var(--green); }
  .scenario-btn.base.active { background: var(--primary-dim); border-color: var(--primary); color: var(--primary); }
  .scenario-btn.pessimistic.active { background: rgba(255,61,113,0.15); border-color: var(--red); color: var(--red); }
  .confidence-bar { height: 4px; border-radius: 2px; background: var(--border); margin-top: 6px; overflow:hidden; }
  .confidence-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--primary), var(--cyan)); }
  .forecast-table-row {
    display: grid; grid-template-columns: 1.6fr repeat(3,1fr) 0.8fr;
    gap: 8px; padding: 10px 14px; border-bottom: 1px solid var(--border);
    align-items: center; font-size: 13px;
  }
  .forecast-table-row:last-child { border-bottom: none; }
  .forecast-table-row.header {
    font-size: 11px; letter-spacing: 1px; color: var(--text3);
    text-transform: uppercase; font-weight: 600;
    background: var(--bg2); border-radius: 8px 8px 0 0;
  }
  .trend-up { color: var(--green); font-size: 11px; font-family: var(--mono); }
  .trend-down { color: var(--red); font-size: 11px; font-family: var(--mono); }
  .trend-flat { color: var(--text3); font-size: 11px; font-family: var(--mono); }
  .insight-card {
    background: var(--bg2); border: 1px solid var(--border2);
    border-radius: 10px; padding: 14px 16px;
    display: flex; gap: 12px; align-items: flex-start; margin-bottom: 10px;
  }
  .insight-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
  .insight-title { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
  .insight-body { font-size: 12px; color: var(--text3); line-height: 1.5; }
  .month-forecast-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 20px; }
  .month-forecast-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px;
  }
  .mfc-month { font-size: 11px; color: var(--text3); font-family: var(--mono); margin-bottom:8px; }
  .mfc-income { font-family: var(--mono); font-size: 14px; color: var(--green); }
  .mfc-expense { font-family: var(--mono); font-size: 14px; color: var(--red); }
  .mfc-net { font-family: var(--mono); font-size: 16px; font-weight: 700; margin-top: 6px; }
  .mfc-label { font-size: 10px; color: var(--text3); }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">▸ SFT v1.0</div>
    <div class="logo-name">Smart Finance<br>Tracker</div>
    <div class="logo-sub">Personal Finance System</div>
  </div>

  <div class="nav-section">
    <div class="nav-label">Overview</div>
    <div class="nav-item active" onclick="showPage('dashboard')">
      <span class="icon">◈</span> Dashboard
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-label">Core</div>
    <div class="nav-item" onclick="showPage('accounts')">
      <span class="icon">⊞</span> Chart of Accounts
    </div>
    <div class="nav-item" onclick="showPage('transactions')">
      <span class="icon">⇄</span> Transactions
    </div>
    <div class="nav-item" onclick="showPage('ledger')">
      <span class="icon">≡</span> Ledger
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-label">Reporting</div>
    <div class="nav-item" onclick="showPage('reports')">
      <span class="icon">◫</span> Financial Reports
    </div>
    <div class="nav-item" onclick="showPage('ratios')">
      <span class="icon">∿</span> Financial Ratios
    </div>
    <div class="nav-item" onclick="showPage('budget')">
      <span class="icon">◎</span> Budget Control
    </div>
    <div class="nav-item" onclick="showPage('forecast')">
      <span class="icon">◬</span> Forecast & Predict
      <span class="nav-badge">AI</span>
    </div>
  </div>

  <div class="sidebar-footer">
    <div style="margin-bottom:10px;">
      <div style="color:var(--text2);font-size:11px;margin-bottom:6px;letter-spacing:0.5px;">BDT ৳ · FY 2025–26 · <span id="txn-count-sb">0</span> txns</div>
    </div>
    <button class="btn btn-outline btn-sm" onclick="exportData()" style="width:100%;margin-bottom:6px;justify-content:center;font-size:12px;">
      ⬇ Export Data (.json)
    </button>
    <label class="btn btn-outline btn-sm" style="width:100%;justify-content:center;cursor:pointer;font-size:12px;display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:8px;border:1px solid var(--border2);color:var(--text2);margin-bottom:6px;">
      ⬆ Import Data (.json)
      <input type="file" accept=".json" id="import-file-input" style="display:none;" onchange="importData(event)">
    </label>
    <button class="btn btn-danger btn-sm" onclick="resetData()" style="width:100%;justify-content:center;font-size:12px;">
      ✕ Reset All Data
    </button>
    <div style="margin-top:10px;font-size:10px;color:var(--text3);line-height:1.5;">Auto-saved to browser.<br>Export to keep data safe.</div>
  </div>
</aside>

<!-- MAIN CONTENT -->
<main class="main">

  <!-- ========== DASHBOARD ========== -->
  <div class="page active" id="page-dashboard">
    <div class="page-header">
      <div>
        <div class="page-title">Dashboard</div>
        <div class="page-sub">Financial overview · <span id="dash-period">All time</span></div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <input type="month" class="form-input" id="dash-month" style="width:160px;" onchange="renderDashboard()">
        <button class="btn btn-outline btn-sm" onclick="document.getElementById('dash-month').value='';renderDashboard()">All Time</button>
      </div>
    </div>

    <div class="kpi-grid">
      <div class="kpi-card income">
        <div class="kpi-label">Total Income</div>
        <div class="kpi-value" id="kpi-income">৳ 0</div>
        <div class="kpi-change" id="kpi-income-sub">—</div>
      </div>
      <div class="kpi-card expense">
        <div class="kpi-label">Total Expenses</div>
        <div class="kpi-value" id="kpi-expense">৳ 0</div>
        <div class="kpi-change" id="kpi-expense-sub">—</div>
      </div>
      <div class="kpi-card profit">
        <div class="kpi-label">Net Profit</div>
        <div class="kpi-value" id="kpi-profit">৳ 0</div>
        <div class="kpi-change" id="kpi-profit-sub">—</div>
      </div>
      <div class="kpi-card cash">
        <div class="kpi-label">Cash Position</div>
        <div class="kpi-value" id="kpi-cash">৳ 0</div>
        <div class="kpi-change" id="kpi-cash-sub">Asset balance</div>
      </div>
    </div>

    <div class="grid-2" style="margin-bottom:16px;">
      <div class="card">
        <div class="card-title">Monthly Income vs Expense</div>
        <div class="chart-wrap-tall"><canvas id="chart-monthly"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">Top Expense Categories</div>
        <div class="chart-wrap-tall"><canvas id="chart-donut"></canvas></div>
      </div>
    </div>

    <div class="grid-2">
      <div class="card">
        <div class="card-title">Recent Transactions</div>
        <div id="dash-recent-txn"></div>
      </div>
      <div class="card">
        <div class="card-title">Cash Flow Trend (6 months)</div>
        <div class="chart-wrap"><canvas id="chart-cashflow"></canvas></div>
      </div>
    </div>
  </div>

  <!-- ========== CHART OF ACCOUNTS ========== -->
  <div class="page" id="page-accounts">
    <div class="page-header">
      <div>
        <div class="page-title">Chart of Accounts</div>
