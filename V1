// ============================================================
// FORECAST & PREDICTION ENGINE
// ============================================================
let fcModel = 'lr';       // lr | ma | es
let fcScenario = 'base';  // base | optimistic | pessimistic
let fcMainChart = null, fcCumChart = null;

const SCENARIO_MULT = { optimistic: { income: 1.15, expense: 0.88 }, base: { income: 1.0, expense: 1.0 }, pessimistic: { income: 0.88, expense: 1.15 } };

function setModel(m) {
  fcModel = m;
  document.querySelectorAll('.model-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('model-'+m).classList.add('active');
  renderForecast();
}

function setScenario(s) {
  fcScenario = s;
  document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('sc-'+s).classList.add('active');
  renderForecast();
}

// --- Math helpers ---
function linReg(ys) {
  const n = ys.length;
  if (n < 2) return { slope: 0, intercept: ys[0] || 0, r2: 0 };
  const xs = ys.map((_, i) => i);
  const mx = xs.reduce((a, b) => a + b, 0) / n;
  const my = ys.reduce((a, b) => a + b, 0) / n;
  const ssxy = xs.reduce((a, x, i) => a + (x - mx) * (ys[i] - my), 0);
  const ssx  = xs.reduce((a, x) => a + (x - mx) ** 2, 0);
  const slope = ssx ? ssxy / ssx : 0;
  const intercept = my - slope * mx;
  const yHat = xs.map(x => slope * x + intercept);
  const ssTot = ys.reduce((a, y) => a + (y - my) ** 2, 0);
  const ssRes = ys.reduce((a, y, i) => a + (y - yHat[i]) ** 2, 0);
  const r2 = ssTot ? Math.max(0, 1 - ssRes / ssTot) : 0;
  const stdErr = n > 2 ? Math.sqrt(ssRes / (n - 2)) : 0;
  return { slope, intercept, r2, stdErr };
}

function movingAvg(ys, win = 3) {
  const last = ys.slice(-win);
  const avg = last.reduce((a, b) => a + b, 0) / last.length;
  // trend from last window
  const trend = last.length > 1 ? (last[last.length-1] - last[0]) / (last.length - 1) : 0;
  // stdErr from last window
  const stdErr = Math.sqrt(last.reduce((a, v) => a + (v - avg) ** 2, 0) / Math.max(1, last.length - 1));
  const r2 = 0.65; // moving average has moderate confidence by nature
  return { avg, trend, stdErr, r2 };
}

function expSmooth(ys, alpha = 0.4) {
  if (!ys.length) return { level: 0, trend: 0, stdErr: 0, r2: 0 };
  let level = ys[0], trend = 0;
  const residuals = [];
  for (let i = 1; i < ys.length; i++) {
    const prevLevel = level;
    level = alpha * ys[i] + (1 - alpha) * (level + trend);
    trend = 0.1 * (level - prevLevel) + 0.9 * trend;
    residuals.push(ys[i] - (prevLevel + trend));
  }
  const stdErr = residuals.length ? Math.sqrt(residuals.reduce((a, r) => a + r * r, 0) / residuals.length) : 0;
  // R2 approximation
  const mean = ys.reduce((a, b) => a + b, 0) / ys.length;
  const ssTot = ys.reduce((a, y) => a + (y - mean) ** 2, 0);
  const ssRes = residuals.reduce((a, r) => a + r * r, 0);
  const r2 = ssTot ? Math.max(0, 1 - ssRes / ssTot) : 0;
  return { level, trend, stdErr, r2 };
}

function forecastValues(ys, horizon) {
  if (!ys.length || ys.every(v => v === 0)) return { predicted: Array(horizon).fill(0), stdErr: 0, r2: 0 };
  const n = ys.length;

  if (fcModel === 'lr') {
    const { slope, intercept, r2, stdErr } = linReg(ys);
    const predicted = Array.from({ length: horizon }, (_, i) => Math.max(0, slope * (n + i) + intercept));
    return { predicted, stdErr, r2 };
  }
  if (fcModel === 'ma') {
    const { avg, trend, stdErr, r2 } = movingAvg(ys, 3);
    const predicted = Array.from({ length: horizon }, (_, i) => Math.max(0, avg + trend * (i + 1)));
    return { predicted, stdErr, r2 };
  }
  if (fcModel === 'es') {
    const { level, trend, stdErr, r2 } = expSmooth(ys, 0.4);
    const predicted = Array.from({ length: horizon }, (_, i) => Math.max(0, level + trend * (i + 1)));
    return { predicted, stdErr, r2 };
  }
  return { predicted: Array(horizon).fill(0), stdErr: 0, r2: 0 };
}

// Build monthly time series from transactions
function buildMonthlySeriesAll(pastMonths) {
  const incomeAccIds = DB.accounts.filter(a => a.type === 'Income').map(a => a.id);
  const expAccIds    = DB.accounts.filter(a => a.type === 'Expense').map(a => a.id);
  const incomes = [], expenses = [];
  pastMonths.forEach(m => {
    let inc = 0, exp = 0;
    DB.transactions.forEach(t => {
      if (!t.date.startsWith(m)) return;
      if (incomeAccIds.includes(t.creditId)) inc += Number(t.amount);
      if (expAccIds.includes(t.debitId))    exp += Number(t.amount);
    });
    incomes.push(inc);
    expenses.push(exp);
  });
  return { incomes, expenses };
}

function getFutureMonths(n) {
  const result = [];
  const now = new Date();
  for (let i = 1; i <= n; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
    result.push(d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0'));
  }
  return result;
}

function monthLabel(m) {
  const [y, mo] = m.split('-');
  return new Date(y, mo - 1).toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
}

function renderForecast() {
  const horizon = parseInt(document.getElementById('fc-horizon').value) || 6;
  const HIST_MONTHS = 12; // look back up to 12 months for training
  const pastMonths = [];
  const now = new Date();
  for (let i = HIST_MONTHS - 1; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    pastMonths.push(d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0'));
  }

  const { incomes, expenses } = buildMonthlySeriesAll(pastMonths);

  // Check for enough data
  const hasData = incomes.some(v => v > 0) || expenses.some(v => v > 0);
  if (!hasData) {
    document.getElementById('fc-insights').innerHTML = '<div class="insight-card"><div class="insight-icon">⚠️</div><div><div class="insight-title">Not enough data</div><div class="insight-body">Add at least 2–3 months of transactions to generate meaningful forecasts.</div></div></div>';
    return;
  }

  // Only use months that have any data for training
  const dataMonths   = pastMonths.filter((_, i) => incomes[i] > 0 || expenses[i] > 0);
  const dataIncomes  = dataMonths.map((_, i) => incomes[pastMonths.indexOf(dataMonths[i])]);
  const dataExpenses = dataMonths.map((_, i) => expenses[pastMonths.indexOf(dataMonths[i])]);

  const futureMonths = getFutureMonths(horizon);
  const smult = SCENARIO_MULT[fcScenario];

  const { predicted: predInc, stdErr: siInc, r2: r2Inc } = forecastValues(dataIncomes, horizon);
  const { predicted: predExp, stdErr: siExp, r2: r2Exp } = forecastValues(dataExpenses, horizon);

  const adjInc = predInc.map(v => v * smult.income);
  const adjExp = predExp.map(v => v * smult.expense);

  // Confidence: weighted average R2 of income and expense models
  const avgR2 = (r2Inc + r2Exp) / 2;
  const confPct = Math.round(avgR2 * 100);
  document.getElementById('fc-kpi-conf').textContent = confPct + '%';
  document.getElementById('fc-conf-bar').style.width = confPct + '%';

  const avgInc  = adjInc.reduce((a, b) => a + b, 0) / horizon;
  const avgExp  = adjExp.reduce((a, b) => a + b, 0) / horizon;
  const avgSave = avgInc - avgExp;
  const lastActInc  = dataIncomes[dataIncomes.length-1] || 0;
  const lastActExp  = dataExpenses[dataExpenses.length-1] || 0;

  const incDelta = lastActInc ? ((avgInc - lastActInc) / lastActInc * 100).toFixed(1) : 0;
  const expDelta = lastActExp ? ((avgExp - lastActExp) / lastActExp * 100).toFixed(1) : 0;

  document.getElementById('fc-kpi-income').textContent = fmt(avgInc);
  document.getElementById('fc-kpi-expense').textContent = fmt(avgExp);
  document.getElementById('fc-kpi-savings').textContent = fmt(avgSave);
  document.getElementById('fc-kpi-income-delta').innerHTML = `<span style="color:${incDelta>=0?'var(--green)':'var(--red)'};">${incDelta>=0?'▲':'▼'}${Math.abs(incDelta)}% vs last month</span>`;
  document.getElementById('fc-kpi-expense-delta').innerHTML = `<span style="color:${expDelta<=0?'var(--green)':'var(--red)'};">${expDelta>=0?'▲':'▼'}${Math.abs(expDelta)}% vs last month</span>`;
  document.getElementById('fc-kpi-savings-delta').innerHTML = `<span style="color:${avgSave>=0?'var(--green)':'var(--red)'};">${avgSave>=0?'Positive':'Negative'} cash flow</span>`;

  // Model stats
  const modelDesc = {
    lr: { name: 'Linear Regression', desc: 'Fits a straight trend line to all historical data points. Best when there is a clear upward or downward trend.', icon: '📈' },
    ma: { name: 'Moving Average', desc: 'Averages the last 3 months to smooth out noise. Best for stable, cyclical patterns.', icon: '〰' },
    es: { name: 'Exponential Smoothing', desc: 'Weights recent months more heavily (α=0.4). Best when recent behaviour matters more than old history.', icon: '◉' }
  };
  const md = modelDesc[fcModel];
  document.getElementById('model-stats').innerHTML = `
    <div style="grid-column:1/3;background:var(--bg4);border-radius:8px;padding:12px 14px;">
      <div style="font-size:12px;font-weight:600;margin-bottom:4px;">${md.icon} ${md.name}</div>
      <div style="font-size:11px;color:var(--text3);">${md.desc}</div>
    </div>
    <div style="background:var(--bg4);border-radius:8px;padding:12px 14px;text-align:center;">
      <div style="font-size:11px;color:var(--text3);margin-bottom:4px;">R² Score</div>
      <div style="font-family:var(--mono);font-size:20px;font-weight:700;color:${avgR2>0.7?'var(--green)':avgR2>0.4?'var(--gold)':'var(--red)'};">${avgR2.toFixed(2)}</div>
      <div style="font-size:10px;color:var(--text3);">${avgR2>0.7?'Good fit':avgR2>0.4?'Moderate fit':'Low fit'}</div>
    </div>`;

  // ---- Main Forecast Chart ----
  const allMonthLabels = [...pastMonths.map(monthLabel), ...futureMonths.map(monthLabel)];
  const histLen = pastMonths.length;

  // Historical data (actual)
  const histInc = pastMonths.map((_, i) => incomes[i]);
  const histExp = pastMonths.map((_, i) => expenses[i]);

  // Pad projected arrays with nulls for historical positions
  const projInc = [...Array(histLen).fill(null), ...adjInc];
  const projExp = [...Array(histLen).fill(null), ...adjExp];

  // Connector: last historical point + first projected
  const connInc = Array(histLen).fill(null);
  const connExp = Array(histLen).fill(null);
  connInc[histLen - 1] = histInc[histLen - 1];
  connInc[histLen]     = adjInc[0];
  connExp[histLen - 1] = histExp[histLen - 1];
  connExp[histLen]     = adjExp[0];

  // Confidence band (income: upper/lower)
  const bandIncUp = [...Array(histLen).fill(null), ...adjInc.map((v, i) => v + siInc * (1 + i * 0.1))];
  const bandIncLo = [...Array(histLen).fill(null), ...adjInc.map((v, i) => Math.max(0, v - siInc * (1 + i * 0.1)))];

  if (fcMainChart) fcMainChart.destroy();
  fcMainChart = new Chart(document.getElementById('chart-forecast-main'), {
    type: 'line',
    data: {
      labels: allMonthLabels,
      datasets: [
        // Confidence band fill (income)
        { label: 'Conf Upper', data: bandIncUp, borderWidth: 0, fill: '+1', backgroundColor: 'rgba(41,121,255,0.07)', pointRadius: 0, tension: 0.4 },
        { label: 'Conf Lower', data: bandIncLo, borderWidth: 0, fill: false, backgroundColor: 'transparent', pointRadius: 0, tension: 0.4 },
        // Historical
        { label: 'Income (Actual)',  data: histInc.concat(Array(horizon).fill(null)), borderColor: '#00e676', backgroundColor: 'transparent', borderWidth: 2.5, pointRadius: 3, pointBackgroundColor: '#00e676', tension: 0.35 },
        { label: 'Expense (Actual)', data: histExp.concat(Array(horizon).fill(null)), borderColor: '#ff3d71', backgroundColor: 'transparent', borderWidth: 2.5, pointRadius: 3, pointBackgroundColor: '#ff3d71', tension: 0.35 },
        // Projected
        { label: 'Income (Forecast)',  data: projInc, borderColor: '#00e676', backgroundColor: 'transparent', borderWidth: 2, borderDash: [6, 4], pointRadius: 3, pointBackgroundColor: '#00e676', tension: 0.35 },
        { label: 'Expense (Forecast)', data: projExp, borderColor: '#ff3d71', backgroundColor: 'transparent', borderWidth: 2, borderDash: [6, 4], pointRadius: 3, pointBackgroundColor: '#ff3d71', tension: 0.35 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { labels: { color: '#8899b8', font: { family: 'DM Sans' }, filter: i => !['Conf Upper','Conf Lower'].includes(i.text) } },
        tooltip: {
          callbacks: {
            label: ctx => {
              if (['Conf Upper','Conf Lower'].includes(ctx.dataset.label)) return null;
              return ' ' + ctx.dataset.label + ': ' + (ctx.raw !== null ? '৳' + Number(ctx.raw).toLocaleString('en-IN') : '—');
            }
          }
        },
        annotation: {} // placeholder
      },
      scales: {
        x: { ticks: { color: '#4a5d80', maxRotation: 45 }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'transparent' } },
        y: { ticks: { color: '#4a5d80', callback: v => '৳' + Number(v).toLocaleString() }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'transparent' } }
      }
    }
  });

  // ---- Month-by-Month Cards ----
  const cardGrid = document.getElementById('fc-month-cards');
  cardGrid.style.gridTemplateColumns = `repeat(${Math.min(horizon, 6)}, 1fr)`;
  cardGrid.innerHTML = futureMonths.map((m, i) => {
    const inc = adjInc[i], exp = adjExp[i], net = inc - exp;
    return `<div class="month-forecast-card">
      <div class="mfc-month">${monthLabel(m)}</div>
      <div class="mfc-label">Income</div>
      <div class="mfc-income">${fmt(inc)}</div>
      <div class="mfc-label" style="margin-top:6px;">Expense</div>
      <div class="mfc-expense">${fmt(exp)}</div>
      <div class="mfc-net" style="color:${net>=0?'var(--green)':'var(--red)'};">${fmt(Math.abs(net))}</div>
      <div class="mfc-label">${net>=0?'Surplus':'Deficit'}</div>
    </div>`;
  }).join('');

  // ---- Category Forecast ----
  const expAccs = DB.accounts.filter(a => a.type === 'Expense');
  const catRows = expAccs.map(acc => {
    const monthlyVals = pastMonths.map(m => {
      let s = 0;
      DB.transactions.forEach(t => { if (t.debitId === acc.id && t.date.startsWith(m)) s += Number(t.amount); });
      return s;
    });
    const avgActual = monthlyVals.reduce((a, b) => a + b, 0) / Math.max(1, monthlyVals.filter(v => v > 0).length || 1);
    const { predicted } = forecastValues(monthlyVals.filter((_, i) => monthlyVals[i] > 0 || i > monthlyVals.findIndex(v => v > 0)), 1);
    const proj = (predicted[0] || 0) * smult.expense;
    const change = avgActual ? ((proj - avgActual) / avgActual * 100) : 0;
    const trend = change > 5 ? `<span class="trend-down">▲ ${change.toFixed(1)}%</span>` : change < -5 ? `<span class="trend-up">▼ ${Math.abs(change).toFixed(1)}%</span>` : `<span class="trend-flat">→ Stable</span>`;
    if (!avgActual && !proj) return '';
    return `<div class="forecast-table-row">
      <span style="font-weight:500;">${acc.name}</span>
      <span class="mono text-muted">${fmt(avgActual)}</span>
      <span class="mono" style="color:${proj>avgActual?'var(--red)':'var(--green)'};">${fmt(proj)}</span>
      <span class="mono" style="color:${change>0?'var(--red)':'var(--green);'};">${change>0?'+':''}${change.toFixed(1)}%</span>
      <span>${trend}</span>
    </div>`;
  }).filter(Boolean).join('');
  document.getElementById('fc-cat-rows').innerHTML = catRows || '<div style="padding:16px;color:var(--text3);font-size:13px;">No expense data found.</div>';

  // ---- Insights ----
  const insights = [];
  const projSavingsTotal = adjInc.reduce((a, b) => a + b, 0) - adjExp.reduce((a, b) => a + b, 0);
  const savingsRate = adjInc.reduce((a,b)=>a+b,0) ? (projSavingsTotal / adjInc.reduce((a,b)=>a+b,0) * 100) : 0;

  if (savingsRate > 20) insights.push({ icon: '💚', title: 'Strong Savings Trajectory', body: `Projected savings rate of ${savingsRate.toFixed(1)}% over the next ${horizon} months. You are on track to build a healthy financial cushion.` });
  else if (savingsRate > 0) insights.push({ icon: '🟡', title: 'Modest Savings Expected', body: `Projected savings rate is ${savingsRate.toFixed(1)}%. Consider reducing variable expenses like dining or entertainment to improve this.` });
  else insights.push({ icon: '🔴', title: 'Deficit Warning', body: `Projections show expenses exceeding income by ${fmt(Math.abs(projSavingsTotal))} over ${horizon} months. Review your largest expense categories immediately.` });

  const topExpAcc = expAccs.map(a => {
    const s = DB.transactions.filter(t => t.debitId === a.id).reduce((acc, t) => acc + Number(t.amount), 0);
    return { name: a.name, total: s };
  }).sort((a, b) => b.total - a.total)[0];
  if (topExpAcc && topExpAcc.total > 0) insights.push({ icon: '📊', title: `Largest Expense: ${topExpAcc.name}`, body: `This category accounts for the most spending historically. Monitoring it closely will have the biggest impact on your forecast accuracy.` });

  if (confPct < 50) insights.push({ icon: '⚠️', title: 'Low Model Confidence', body: `R² = ${avgR2.toFixed(2)}. Forecasts are less reliable with fewer or irregular historical data points. Add more months of data for better predictions.` });
  else if (confPct >= 80) insights.push({ icon: '✅', title: 'High Model Confidence', body: `R² = ${avgR2.toFixed(2)}. Your transaction history shows a consistent pattern, making these projections highly reliable.` });

  const incTrend = adjInc[horizon-1] - adjInc[0];
  if (incTrend > 1000) insights.push({ icon: '📈', title: 'Income Growth Detected', body: `The model projects income growing by ${fmt(incTrend)} from the first to last forecasted month &#8212; a positive signal.` });
  if (incTrend < -1000) insights.push({ icon: '📉', title: 'Income Decline Risk', body: `Income is projected to decrease by ${fmt(Math.abs(incTrend))} over the forecast period. Verify if this reflects real expectations.` });

  document.getElementById('fc-insights').innerHTML = insights.map(ins => `
    <div class="insight-card">
      <div class="insight-icon">${ins.icon}</div>
      <div><div class="insight-title">${ins.title}</div><div class="insight-body">${ins.body}</div></div>
    </div>`).join('');

  // ---- Cumulative Savings Chart ----
  const currentCash = DB.accounts.filter(a => a.type === 'Asset').reduce((s, a) => s + getAccountBalance(a.id), 0);
  let cumulative = currentCash;
  const cumLabels = ['Now', ...futureMonths.map(monthLabel)];
  const cumData = [currentCash, ...adjInc.map((inc, i) => { cumulative += inc - adjExp[i]; return cumulative; })];
  const cumColors = cumData.map(v => v >= currentCash ? 'rgba(0,230,118,0.7)' : 'rgba(255,61,113,0.7)');

  if (fcCumChart) fcCumChart.destroy();
  fcCumChart = new Chart(document.getElementById('chart-forecast-cumulative'), {
    type: 'bar',
    data: {
      labels: cumLabels,
      datasets: [{
        label: 'Projected Net Balance',
        data: cumData,
        backgroundColor: cumColors,
        borderRadius: 5
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ' Balance: ৳' + Number(ctx.raw).toLocaleString('en-IN') } } },
      scales: {
        x: { ticks: { color: '#4a5d80' }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'transparent' } },
        y: { ticks: { color: '#4a5d80', callback: v => '৳' + Number(v).toLocaleString() }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'transparent' } }
      }
    }
  });
}


// ============================================================
// DATA EXPORT / IMPORT / RESET
// ============================================================
function exportData() {
  const payload = {
    version: '1.0',
    exportedAt: new Date().toISOString(),
    currency: 'BDT',
    data: DB
  };
  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  const date = new Date().toISOString().split('T')[0];
  a.download = `smart-finance-tracker-${date}.json`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('Data exported successfully ✓');
}

function importData(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const parsed = JSON.parse(e.target.result);
      // Support both raw DB and wrapped export format
      const incoming = parsed.data || parsed;
      if (!incoming.accounts || !incoming.transactions) {
        showToast('Invalid file: missing accounts or transactions', 'error');
        return;
      }
      if (!confirm(`This will replace all current data with ${incoming.transactions.length} transactions and ${incoming.accounts.length} accounts from the file.\n\nContinue?`)) return;
      DB = incoming;
      if (!DB.budgets) DB.budgets = [];
      saveDB();
      populateTxnAccountDropdowns();
      updateSidebarCount();
      showPage('dashboard');
      showToast(`Imported ${DB.transactions.length} transactions ✓`);
    } catch(err) {
      showToast('Failed to read file: ' + err.message, 'error');
    }
    // Reset file input so same file can be re-imported
    event.target.value = '';
  };
  reader.readAsText(file);
}

function resetData() {
  if (!confirm('This will permanently delete ALL your data — accounts, transactions, and budgets.\n\nAre you absolutely sure?')) return;
  if (!confirm('Last warning: all data will be wiped and defaults will be restored. Continue?')) return;
  localStorage.removeItem('sft_db');
  seedDefaults();
  loadDB();
  populateTxnAccountDropdowns();
  updateSidebarCount();
  showPage('dashboard');
  showToast('Data reset to defaults');
}

// ============================================================
// INIT
// ============================================================
loadDB();
populateTxnAccountDropdowns();
renderDashboard();
updateSidebarCount();

// Set default report dates
const now = new Date();
const firstOfYear = new Date(now.getFullYear(),0,1).toISOString().split('T')[0];
document.getElementById('rpt-from').value = firstOfYear;
document.getElementById('rpt-to').value = now.toISOString().split('T')[0];
document.getElementById('budget-month').value = now.toISOString().slice(0,7);
document.getElementById('dash-month').value = '';

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if(e.target===o) closeModal(o.id); });
});
</script>
