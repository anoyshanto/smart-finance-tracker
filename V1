// ACCOUNT BALANCE CALCULATION
// ============================================================
function getAccountBalance(accId, dateFrom, dateTo) {
  const acc = getAcc(accId);
  let opening = Number(acc.openingBalance||0);
  let dr = 0, cr = 0;
  DB.transactions.forEach(t => {
    if(dateFrom && t.date < dateFrom) return;
    if(dateTo && t.date > dateTo) return;
    if(t.debitId===accId) dr += Number(t.amount);
    if(t.creditId===accId) cr += Number(t.amount);
  });
  // Normal balance logic
  if(['Asset','Expense'].includes(acc.type)) return opening + dr - cr;
  else return opening + cr - dr;
}

function getAccountMovement(accId, dateFrom, dateTo) {
  let dr = 0, cr = 0;
  DB.transactions.forEach(t => {
    if(dateFrom && t.date < dateFrom) return;
    if(dateTo && t.date > dateTo) return;
    if(t.debitId===accId) dr += Number(t.amount);
    if(t.creditId===accId) cr += Number(t.amount);
  });
  return {dr, cr};
}

