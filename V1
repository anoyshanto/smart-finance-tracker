function renderLedger() {
  const accId = document.getElementById('ledger-account').value;
  const dateFrom = document.getElementById('ledger-from').value;
  const dateTo = document.getElementById('ledger-to').value;
  const tbody = document.getElementById('ledger-tbody');
  const sumEl = document.getElementById('ledger-summary');

  if(!accId) {
    tbody.innerHTML=`<tr><td colspan="5"><div class="empty"><div class="empty-icon">≡</div><div class="empty-text">Select an account to view ledger</div></div></td></tr>`;
    sumEl.style.display='none'; return;
  }

  const acc = getAcc(accId);
  const openingBal = Number(acc.openingBalance||0);
  let txns = DB.transactions.filter(t => {
    if(t.debitId!==accId && t.creditId!==accId) return false;
    if(dateFrom && t.date < dateFrom) return false;
    if(dateTo && t.date > dateTo) return false;
    return true;
  }).sort((a,b)=>a.date.localeCompare(b.date));

  let running = openingBal;
  let totalDr=0, totalCr=0;

  const isNormalDebit = ['Asset','Expense'].includes(acc.type);
  const rows = txns.map(t => {
    const isDr = t.debitId===accId;
    const dr = isDr?Number(t.amount):0;
    const cr = !isDr?Number(t.amount):0;
    totalDr+=dr; totalCr+=cr;
    running += isNormalDebit ? (dr-cr) : (cr-dr);
    const other = isDr ? getAcc(t.creditId).name : getAcc(t.debitId).name;
    return `<tr>
      <td class="mono" style="font-size:12px;">${t.date}</td>
      <td>${t.remarks||'—'} <span style="font-size:11px;color:var(--text3);">${other?'↔ '+other:''}</span></td>
      <td class="mono text-green">${dr?fmtN(dr):''}</td>
      <td class="mono text-red">${cr?fmtN(cr):''}</td>
      <td class="mono text-primary">${fmtN(running)}</td>
    </tr>`;
  });

  if(!rows.length) {
    tbody.innerHTML=`<tr><td colspan="5"><div class="empty"><div class="empty-icon">≡</div><div class="empty-text">No transactions for this account in selected period</div></div></td></tr>`;
  } else {
    tbody.innerHTML = `<tr style="background:var(--bg2);">
      <td class="mono" style="font-size:12px;color:var(--text3);">Opening</td>
      <td style="color:var(--text3);">Opening Balance</td><td></td><td></td>
      <td class="mono text-muted">${fmtN(openingBal)}</td>
    </tr>` + rows.join('') +
    `<tr style="background:var(--bg2);font-weight:700;">
      <td colspan="2" style="font-size:12px;">CLOSING BALANCE</td>
      <td class="mono text-green">${fmtN(totalDr)}</td>
      <td class="mono text-red">${fmtN(totalCr)}</td>
      <td class="mono text-gold">${fmtN(running)}</td>
    </tr>`;
  }

  sumEl.style.display='block';
  document.getElementById('led-open').textContent=fmt(openingBal);
  const netMov = isNormalDebit?(totalDr-totalCr):(totalCr-totalDr);
  document.getElementById('led-movement').textContent=fmt(netMov);
  document.getElementById('led-movement').className='ledger-balance '+(netMov>=0?'text-green':'text-red');
  document.getElementById('led-close').textContent=fmt(running);
}

