function renderPL(from,to) {
  const el = document.getElementById('report-pl');
  const incAccs = DB.accounts.filter(a=>a.type==='Income');
  const expAccs = DB.accounts.filter(a=>a.type==='Expense');

  let totalIncome=0, totalExpense=0;
  const incRows = incAccs.map(a=>{
    const {cr} = getAccountMovement(a.id,from,to);
    totalIncome+=cr;
    return `<div class="report-row sub"><span>${a.name}</span><span class="report-val text-green">${fmtN(cr)}</span></div>`;
  }).join('');
  const expRows = expAccs.map(a=>{
    const {dr} = getAccountMovement(a.id,from,to);
    totalExpense+=dr;
    return `<div class="report-row sub"><span>${a.name}</span><span class="report-val text-red">${fmtN(dr)}</span></div>`;
  }).join('');

  const net = totalIncome-totalExpense;
  el.innerHTML = `
    <div style="text-align:center;margin-bottom:20px;">
      <div style="font-size:18px;font-weight:700;">Profit & Loss Statement</div>
      <div style="font-size:12px;color:var(--text3);">${from||'All'} to ${to||'Present'}</div>
    </div>
    <div class="report-section">
      <h3>Income</h3>${incRows}
      <div class="report-row total"><span>Total Income</span><span class="report-val text-green">${fmtN(totalIncome)}</span></div>
    </div>
    <div class="report-section">
      <h3>Expenses</h3>${expRows}
      <div class="report-row total"><span>Total Expenses</span><span class="report-val text-red">${fmtN(totalExpense)}</span></div>
