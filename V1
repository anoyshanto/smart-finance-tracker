let monthlyChart, donutChart, cashflowChart;

function renderDashboard() {
  const monthFilter = document.getElementById('dash-month').value;
  let dateFrom, dateTo;
  if(monthFilter) {
    dateFrom = monthFilter+'-01';
    const d = new Date(monthFilter+'-01');
    d.setMonth(d.getMonth()+1); d.setDate(0);
    dateTo = d.toISOString().split('T')[0];
    document.getElementById('dash-period').textContent = new Date(dateFrom).toLocaleDateString('en-US',{month:'long',year:'numeric'});
  } else {
    document.getElementById('dash-period').textContent = 'All time';
  }

  // KPIs
  let totalIncome=0, totalExpense=0;
  const incomeAccs = DB.accounts.filter(a=>a.type==='Income').map(a=>a.id);
  const expenseAccs = DB.accounts.filter(a=>a.type==='Expense').map(a=>a.id);
  const assetAccs = DB.accounts.filter(a=>a.type==='Asset').map(a=>a.id);

  DB.transactions.forEach(t => {
    if(dateFrom && t.date < dateFrom) return;
    if(dateTo && t.date > dateTo) return;
    if(incomeAccs.includes(t.creditId)) totalIncome += Number(t.amount);
    if(expenseAccs.includes(t.debitId)) totalExpense += Number(t.amount);
  });
  const netProfit = totalIncome - totalExpense;
  let cashPos = 0;
  assetAccs.forEach(id => cashPos += getAccountBalance(id));

  document.getElementById('kpi-income').textContent = fmt(totalIncome);
  document.getElementById('kpi-expense').textContent = fmt(totalExpense);
  document.getElementById('kpi-profit').textContent = fmt(netProfit);
  document.getElementById('kpi-cash').textContent = fmt(cashPos);
  document.getElementById('kpi-profit-sub').textContent = totalIncome ? 'Margin: '+(netProfit/totalIncome*100).toFixed(1)+'%' : '—';
  document.getElementById('kpi-income-sub').textContent = incomeAccs.length+' income accounts';
  document.getElementById('kpi-expense-sub').textContent = expenseAccs.length+' expense accounts';

  // Monthly chart
  const months = getLast6Months();
  const monthlyIncome = months.map(m => {
    let s=0; DB.transactions.forEach(t=>{
      if(t.date.startsWith(m) && incomeAccs.includes(t.creditId)) s+=Number(t.amount);
    }); return s;
  });
  const monthlyExpense = months.map(m => {
    let s=0; DB.transactions.forEach(t=>{
      if(t.date.startsWith(m) && expenseAccs.includes(t.debitId)) s+=Number(t.amount);
    }); return s;
  });
  const monthLabels = months.map(m => {
    const [y,mo]=m.split('-');
    return new Date(y,mo-1).toLocaleDateString('en-US',{month:'short'});
  });

  if(monthlyChart) monthlyChart.destroy();
  monthlyChart = new Chart(document.getElementById('chart-monthly'), {
    type:'bar',
    data:{
      labels:monthLabels,
      datasets:[
        {label:'Income',data:monthlyIncome,backgroundColor:'rgba(0,230,118,0.7)',borderRadius:4},
        {label:'Expense',data:monthlyExpense,backgroundColor:'rgba(255,61,113,0.7)',borderRadius:4}
      ]
    },
    options:{...chartDefaults(), plugins:{legend:{labels:{color:'#8899b8',font:{family:'DM Sans'}}}}}
  });

  // Donut
  const expCats = {};
  DB.transactions.forEach(t=>{
    if(dateFrom && t.date<dateFrom) return;
    if(dateTo && t.date>dateTo) return;
    if(expenseAccs.includes(t.debitId)) {
      const acc = getAcc(t.debitId);
      expCats[acc.name] = (expCats[acc.name]||0)+Number(t.amount);
    }
  });
  const catKeys = Object.keys(expCats).sort((a,b)=>expCats[b]-expCats[a]).slice(0,6);
  const donutColors = ['#2979ff','#00e676','#f5c518','#ff3d71','#00e5ff','#d500f9'];

  if(donutChart) donutChart.destroy();
  if(catKeys.length>0) {
    donutChart = new Chart(document.getElementById('chart-donut'),{
      type:'doughnut',
      data:{
        labels:catKeys,
        datasets:[{data:catKeys.map(k=>expCats[k]),backgroundColor:donutColors,borderWidth:0,hoverOffset:6}]
      },
      options:{...chartDefaults(),cutout:'65%',plugins:{legend:{position:'right',labels:{color:'#8899b8',font:{family:'DM Sans'},boxWidth:12}}}}
    });
  }

  // Cashflow
  const cfData = months.map(m => {
    let income=0,expense=0;
    DB.transactions.forEach(t=>{
      if(!t.date.startsWith(m)) return;
      if(incomeAccs.includes(t.creditId)) income+=Number(t.amount);
      if(expenseAccs.includes(t.debitId)) expense+=Number(t.amount);
    });
    return income-expense;
  });
  if(cashflowChart) cashflowChart.destroy();
  cashflowChart = new Chart(document.getElementById('chart-cashflow'),{
    type:'line',
    data:{
      labels:monthLabels,
      datasets:[{
        label:'Net Cash Flow',data:cfData,
        borderColor:'#2979ff',backgroundColor:'rgba(41,121,255,0.1)',
        fill:true,tension:0.4,pointBackgroundColor:'#2979ff',pointRadius:4
      }]
    },
    options:{...chartDefaults(),plugins:{legend:{display:false}}}
  });

  // Recent txns
  const recent = [...DB.transactions].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,5);
  const el = document.getElementById('dash-recent-txn');
  if(!recent.length) { el.innerHTML='<div class="empty"><div class="empty-icon">⇄</div><div class="empty-text">No transactions yet</div></div>'; return; }
  el.innerHTML = '<table style="width:100%;border-collapse:collapse;font-size:13px;">'
    + recent.map(t=>{
      const isIncome = incomeAccs.includes(t.creditId);
      const isExp = expenseAccs.includes(t.debitId);
      const color = isIncome?'var(--green)':isExp?'var(--red)':'var(--text2)';
      return `<tr style="border-bottom:1px solid var(--border);">
        <td style="padding:8px 0;color:var(--text3);font-size:11px;">${t.date}</td>
        <td style="padding:8px;">${t.remarks||getAcc(t.debitId).name}</td>
        <td style="padding:8px;font-family:var(--mono);color:${color};text-align:right;">${isIncome?'+':isExp?'-':''}${fmt(t.amount)}</td>
      </tr>`;
    }).join('')+'</table>';
}

function getLast6Months() {
  const result=[];
  const now = new Date();
  for(let i=5;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    result.push(d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'));
  }
  return result;
}

function chartDefaults() {
  return {
    responsive:true, maintainAspectRatio:false,
    plugins:{legend:{labels:{color:'#8899b8'}}},
    scales:{
      x:{ticks:{color:'#4a5d80'},grid:{color:'rgba(255,255,255,0.04)'},border:{color:'transparent'}},
      y:{ticks:{color:'#4a5d80',callback:v=>'৳'+Number(v).toLocaleString()},grid:{color:'rgba(255,255,255,0.04)'},border:{color:'transparent'}}
    }
  };
}

