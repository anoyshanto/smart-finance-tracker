let editingAccId = null;
function openAccountModal(id=null) {
  editingAccId = id;
  document.getElementById('acc-modal-title').textContent = id?'Edit Account':'Add Account';
  document.getElementById('acc-error').style.display='none';
  if(id) {
    const a = getAcc(id);
    document.getElementById('acc-name').value = a.name;
    document.getElementById('acc-type').value = a.type;
    document.getElementById('acc-opening').value = a.openingBalance;
    populateParentAccounts();
    document.getElementById('acc-parent').value = a.parentId||'';
  } else {
    document.getElementById('acc-name').value='';
    document.getElementById('acc-type').value='';
    document.getElementById('acc-opening').value='0';
    document.getElementById('acc-parent').innerHTML='<option value="">None (top-level)</option>';
  }
  openModal('modal-account');
}

function editAccount(id) { openAccountModal(id); }

function populateParentAccounts() {
  const type = document.getElementById('acc-type').value;
  const sel = document.getElementById('acc-parent');
  const same = DB.accounts.filter(a=>a.type===type && a.id!==editingAccId);
  sel.innerHTML = '<option value="">None (top-level)</option>' +
    same.map(a=>`<option value="${a.id}">${a.name}</option>`).join('');
}

function saveAccount() {
  const name = document.getElementById('acc-name').value.trim();
  const type = document.getElementById('acc-type').value;
  const parentId = document.getElementById('acc-parent').value;
  const opening = parseFloat(document.getElementById('acc-opening').value)||0;
  const errEl = document.getElementById('acc-error');
  if(!name||!type) { errEl.textContent='Name and type are required.'; errEl.style.display='block'; return; }
  if(DB.accounts.find(a=>a.name.toLowerCase()===name.toLowerCase()&&a.id!==editingAccId)) {
    errEl.textContent='Account name already exists.'; errEl.style.display='block'; return;
  }
  if(editingAccId) {
    const a = getAcc(editingAccId);
    a.name=name; a.type=type; a.parentId=parentId; a.openingBalance=opening;
  } else {
    DB.accounts.push({id:uid(),name,type,parentId,openingBalance:opening});
  }
  saveDB(); closeModal('modal-account'); renderCOA();
  showToast(editingAccId?'Account updated':'Account created');
}

function deleteAccount(id) {
  const used = DB.transactions.some(t=>t.debitId===id||t.creditId===id);
  if(used) { showToast('Cannot delete: account has transactions','error'); return; }
  if(!confirm('Delete this account?')) return;
  DB.accounts = DB.accounts.filter(a=>a.id!==id);
  saveDB(); renderCOA(); showToast('Account deleted');
}

