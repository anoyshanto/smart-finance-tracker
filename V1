function saveTransaction() {
  const date = document.getElementById('txn-date').value;
  const amount = parseFloat(document.getElementById('txn-amount').value);
  const debitId = document.getElementById('txn-debit').value;
  const creditId = document.getElementById('txn-credit').value;
  const category = document.getElementById('txn-category').value;
  const remarks = document.getElementById('txn-remarks').value.trim();
  const ref = document.getElementById('txn-ref').value.trim();
  const errEl = document.getElementById('txn-error');

  if(!date||!amount||!debitId||!creditId) { errEl.textContent='Date, amount, debit and credit accounts are required.'; errEl.style.display='block'; return; }
  if(amount<=0) { errEl.textContent='Amount must be greater than zero.'; errEl.style.display='block'; return; }
  if(debitId===creditId) { errEl.textContent='Debit and Credit accounts cannot be the same.'; errEl.style.display='block'; return; }

  if(editingTxnId) {
    const t = DB.transactions.find(x=>x.id===editingTxnId);
    Object.assign(t,{date,amount,debitId,creditId,category,remarks,ref});
  } else {
    DB.transactions.push({id:uid(),date,amount,debitId,creditId,category,remarks,ref});
  }
  saveDB(); closeModal('modal-txn'); renderTxns(); updateSidebarCount();
  showToast(editingTxnId?'Transaction updated':'Transaction posted ✓');
}

function deleteTransaction(id) {
  if(!confirm('Delete this transaction?')) return;
  DB.transactions = DB.transactions.filter(t=>t.id!==id);
  saveDB(); renderTxns(); updateSidebarCount(); showToast('Transaction deleted');
}

function clearTxnFilters() {
  document.getElementById('txn-date-from').value='';
  document.getElementById('txn-date-to').value='';
  document.getElementById('txn-filter-acc').value='';
  document.getElementById('txn-search').value='';
  renderTxns();
}

function renderTxns() {
  const dateFrom = document.getElementById('txn-date-from').value;
  const dateTo = document.getElementById('txn-date-to').value;
  const accFilter = document.getElementById('txn-filter-acc').value;
  const search = document.getElementById('txn-search').value.toLowerCase();

  let txns = [...DB.transactions].filter(t => {
    if(dateFrom && t.date < dateFrom) return false;
    if(dateTo && t.date > dateTo) return false;
    if(accFilter && t.debitId!==accFilter && t.creditId!==accFilter) return false;
    if(search && !(t.remarks||'').toLowerCase().includes(search) && !(t.ref||'').toLowerCase().includes(search)) return false;
    return true;
  }).sort((a,b)=>b.date.localeCompare(a.date));

  const tbody = document.getElementById('txn-tbody');
  if(!txns.length) {
    tbody.innerHTML=`<tr><td colspan="8"><div class="empty"><div class="empty-icon">⇄</div><div class="empty-text">No transactions found</div></div></td></tr>`;
    document.getElementById('txn-count').textContent='0';
    document.getElementById('txn-total').textContent='৳ 0';
    return;
  }

  let total=0;
  tbody.innerHTML = txns.map((t,i)=>{
    total+=Number(t.amount);
    const dr = getAcc(t.debitId); const cr = getAcc(t.creditId);
    return `<tr>
      <td class="mono text-muted">${String(i+1).padStart(3,'0')}</td>
      <td class="mono" style="font-size:12px;">${t.date}</td>
      <td><span class="badge badge-${dr.type.toLowerCase()}" style="font-size:10px;">${dr.name}</span></td>
      <td><span class="badge badge-${cr.type.toLowerCase()}" style="font-size:10px;">${cr.name}</span></td>
      <td class="mono text-gold">${fmtN(t.amount)}</td>
      <td style="font-size:12px;color:var(--text3);">${t.category||'—'}</td>
      <td style="font-size:12px;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${t.remarks||'—'}</td>
      <td>
        <button class="btn btn-outline btn-sm" onclick="openTxnModal('${t.id}')" style="margin-right:4px;">✎</button>
        <button class="btn btn-danger btn-sm" onclick="deleteTransaction('${t.id}')">✕</button>
      </td>
    </tr>`;
  }).join('');
  document.getElementById('txn-count').textContent=txns.length;
  document.getElementById('txn-total').textContent=fmt(total);
}

